// DockyDoc — Prisma Schema
// PostgreSQL datasource
//
// After any schema change:
//   npx prisma migrate dev --name <migration_name>
//   npx prisma generate

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ================================================================== //
// Enums
// ================================================================== //

enum WorkspaceType {
  PERSONAL
  FAMILY
  ENTERPRISE
}

enum WorkspaceStatus {
  ACTIVE
  INACTIVE
}

enum WorkspaceUserRole {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

enum WorkspaceUserStatus {
  ACTIVE
  INVITED
  REMOVED
}

enum DocumentStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

enum ReminderChannel {
  IN_APP
  EMAIL
}

enum ReminderStatus {
  PENDING
  SENT
  CANCELLED
}

enum ShareType {
  INTERNAL
  EXTERNAL_LINK
}

enum SharePermission {
  VIEW
  DOWNLOAD
}

enum ShareAccessType {
  VIEW
  DOWNLOAD
}

enum AuditAction {
  DOCUMENT_CREATED
  DOCUMENT_UPDATED
  DOCUMENT_DELETED
  DOCUMENT_SHREDDED
  DOCUMENT_VERSION_ADDED
  DOCUMENT_DOWNLOADED
  DOCUMENT_SHARED_INTERNAL
  DOCUMENT_SHARED_EXTERNAL
  SHARE_REVOKED
  REMINDER_CREATED
  REMINDER_UPDATED
  MEMBER_ADDED
  MEMBER_ROLE_UPDATED
}

enum AuditEntityType {
  DOCUMENT
  DOCUMENT_VERSION
  SHARE
  REMINDER
  USER
  WORKSPACE
}

enum WorkspacePlan {
  FREE
  PRO
  ENTERPRISE
}

enum AiProvider {
  PLATFORM
  BYOK
}

enum AiProviderType {
  ANTHROPIC
  OPENAI
}

// ================================================================== //
// Core models
// ================================================================== //

model User {
  id           String   @id @default(cuid())
  clerkId      String?  @unique
  email        String   @unique
  firstName    String
  lastName     String
  passwordHash String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspaces             WorkspaceUser[]
  createdFolders         Folder[]                @relation("FolderCreator")
  ownedDocuments         Document[]              @relation("DocumentOwner")
  uploadedVersions       DocumentVersion[]       @relation("VersionUploader")
  createdShares          DocumentShare[]         @relation("ShareCreator")
  receivedInternalShares InternalDocumentShare[] @relation("InternalShareRecipient")
  shareAccessLogs        ShareAccessLog[]        @relation("ShareAccessor")
  auditLogs              AuditLog[]

  @@map("users")
}

model Workspace {
  id                  String          @id @default(cuid())
  name                String
  slug                String          @unique
  type                WorkspaceType   @default(PERSONAL)
  status              WorkspaceStatus @default(ACTIVE)
  trashRetentionDays  Int             @default(30)
  plan               WorkspacePlan  @default(FREE)
  aiProvider         AiProvider     @default(PLATFORM)
  aiProviderType     AiProviderType @default(ANTHROPIC)
  aiApiKeyEncrypted  String?
  aiUsageTokens      Int            @default(0)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  members      WorkspaceUser[]
  folders      Folder[]
  documents    Document[]
  documentTags DocumentTag[]
  auditLogs    AuditLog[]

  @@map("workspaces")
}

model WorkspaceUser {
  id          String              @id @default(cuid())
  userId      String
  workspaceId String
  role        WorkspaceUserRole   @default(VIEWER)
  status      WorkspaceUserStatus @default(ACTIVE)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@map("workspace_users")
}

// ================================================================== //
// Document domain
// ================================================================== //

model Folder {
  id             String   @id @default(cuid())
  workspaceId    String
  name           String
  parentFolderId String?
  createdById    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy    User      @relation("FolderCreator", fields: [createdById], references: [id])
  parentFolder Folder?   @relation("FolderChildren", fields: [parentFolderId], references: [id])
  children     Folder[]  @relation("FolderChildren")
  documents    Document[]

  @@index([workspaceId])
  @@index([parentFolderId])
  @@map("folders")
}

model Document {
  id                   String         @id @default(cuid())
  workspaceId          String
  folderId             String?
  ownerUserId          String
  name                 String
  description          String?
  fileName             String
  fileType             String
  status               DocumentStatus @default(ACTIVE)
  currentVersionNumber Int            @default(1)
  expiryDate           DateTime?
  renewalDueDate       DateTime?
  isReminderEnabled    Boolean        @default(false)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  workspace     Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  folder        Folder?                @relation(fields: [folderId], references: [id], onDelete: SetNull)
  owner         User                   @relation("DocumentOwner", fields: [ownerUserId], references: [id])
  versions      DocumentVersion[]
  tags          DocumentTagMapping[]
  metadata      DocumentMetadata[]
  reminders     DocumentReminder[]
  shares        DocumentShare[]
  searchContent DocumentSearchContent?

  @@index([workspaceId])
  @@index([workspaceId, folderId])
  @@index([workspaceId, status])
  @@index([ownerUserId])
  @@map("documents")
}

model DocumentVersion {
  id            String   @id @default(cuid())
  documentId    String
  versionNumber Int
  storageKey    String
  fileSizeBytes BigInt
  mimeType      String
  uploadedById  String
  createdAt     DateTime @default(now())

  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  uploadedBy User     @relation("VersionUploader", fields: [uploadedById], references: [id])

  @@unique([documentId, versionNumber])
  @@map("document_versions")
}

model DocumentTag {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  color       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  documents DocumentTagMapping[]

  @@index([workspaceId])
  @@map("document_tags")
}

model DocumentTagMapping {
  id         String @id @default(cuid())
  documentId String
  tagId      String

  document Document    @relation(fields: [documentId], references: [id], onDelete: Cascade)
  tag      DocumentTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([documentId, tagId])
  @@map("document_tag_mappings")
}

model DocumentMetadata {
  id         String   @id @default(cuid())
  documentId String
  key        String
  value      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, key])
  @@index([documentId])
  @@map("document_metadata")
}

// ================================================================== //
// Search
// ================================================================== //

model DocumentSearchContent {
  id            String   @id @default(cuid())
  documentId    String   @unique
  extractedText String   @db.Text
  lastIndexedAt DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("document_search_content")
}

// ================================================================== //
// Document Sharing
// ================================================================== //

model DocumentShare {
  id            String     @id @default(cuid())
  documentId    String
  createdById   String
  shareType     ShareType
  token         String?    @unique
  passwordHash  String?
  expiresAt     DateTime?
  allowDownload Boolean    @default(true)
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  document       Document               @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdBy      User                   @relation("ShareCreator", fields: [createdById], references: [id])
  internalShares InternalDocumentShare[]
  accessLogs     ShareAccessLog[]

  @@index([documentId])
  @@index([token])
  @@index([documentId, isActive])
  @@map("document_shares")
}

model InternalDocumentShare {
  id               String          @id @default(cuid())
  documentShareId  String
  sharedWithUserId String
  permission       SharePermission @default(VIEW)
  createdAt        DateTime        @default(now())

  documentShare  DocumentShare @relation(fields: [documentShareId], references: [id], onDelete: Cascade)
  sharedWithUser User          @relation("InternalShareRecipient", fields: [sharedWithUserId], references: [id])

  @@unique([documentShareId, sharedWithUserId])
  @@index([sharedWithUserId])
  @@map("internal_document_shares")
}

model ShareAccessLog {
  id               String          @id @default(cuid())
  documentShareId  String
  accessedAt       DateTime        @default(now())
  ipAddress        String?
  userAgent        String?
  accessType       ShareAccessType
  accessedByUserId String?
  createdAt        DateTime        @default(now())

  documentShare  DocumentShare @relation(fields: [documentShareId], references: [id], onDelete: Cascade)
  accessedByUser User?         @relation("ShareAccessor", fields: [accessedByUserId], references: [id])

  @@index([documentShareId])
  @@index([accessedAt])
  @@map("share_access_logs")
}

model DocumentReminder {
  id         String          @id @default(cuid())
  documentId String
  remindAt   DateTime
  channel    ReminderChannel @default(IN_APP)
  status     ReminderStatus  @default(PENDING)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([status, remindAt])
  @@map("document_reminders")
}

// ================================================================== //
// Audit Logs
// ================================================================== //

model AuditLog {
  id          String          @id @default(cuid())
  workspaceId String
  userId      String?
  action      AuditAction
  entityType  AuditEntityType
  entityId    String
  metadata    Json?
  createdAt   DateTime        @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([entityId])
  @@index([createdAt])
  @@index([workspaceId, createdAt])
  @@map("audit_logs")
}
