// DockyDoc — Prisma Schema
// PostgreSQL datasource
//
// After any schema change:
//   npx prisma migrate dev --name <migration_name>
//   npx prisma generate

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ================================================================== //
// Enums
// ================================================================== //

enum WorkspaceType {
  PERSONAL
  FAMILY
  ENTERPRISE
}

enum WorkspaceStatus {
  ACTIVE
  INACTIVE
}

enum WorkspaceUserRole {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

enum WorkspaceUserStatus {
  ACTIVE
  INVITED
  REMOVED
}

enum DocumentStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

// ================================================================== //
// Core models
// ================================================================== //

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  firstName String
  lastName  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaces       WorkspaceUser[]
  createdFolders   Folder[]          @relation("FolderCreator")
  ownedDocuments   Document[]        @relation("DocumentOwner")
  uploadedVersions DocumentVersion[] @relation("VersionUploader")

  @@map("users")
}

model Workspace {
  id        String          @id @default(cuid())
  name      String
  slug      String          @unique
  type      WorkspaceType   @default(PERSONAL)
  status    WorkspaceStatus @default(ACTIVE)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  members      WorkspaceUser[]
  folders      Folder[]
  documents    Document[]
  documentTags DocumentTag[]

  @@map("workspaces")
}

model WorkspaceUser {
  id          String              @id @default(cuid())
  userId      String
  workspaceId String
  role        WorkspaceUserRole   @default(VIEWER)
  status      WorkspaceUserStatus @default(ACTIVE)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@map("workspace_users")
}

// ================================================================== //
// Document domain
// ================================================================== //

model Folder {
  id             String   @id @default(cuid())
  workspaceId    String
  name           String
  parentFolderId String?
  createdById    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy    User      @relation("FolderCreator", fields: [createdById], references: [id])
  parentFolder Folder?   @relation("FolderChildren", fields: [parentFolderId], references: [id])
  children     Folder[]  @relation("FolderChildren")
  documents    Document[]

  @@index([workspaceId])
  @@index([parentFolderId])
  @@map("folders")
}

model Document {
  id                   String         @id @default(cuid())
  workspaceId          String
  folderId             String?
  ownerUserId          String
  name                 String
  description          String?
  fileName             String
  fileType             String
  status               DocumentStatus @default(ACTIVE)
  currentVersionNumber Int            @default(1)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  workspace     Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  folder        Folder?                @relation(fields: [folderId], references: [id], onDelete: SetNull)
  owner         User                   @relation("DocumentOwner", fields: [ownerUserId], references: [id])
  versions      DocumentVersion[]
  tags          DocumentTagMapping[]
  metadata      DocumentMetadata[]
  searchContent DocumentSearchContent?

  @@index([workspaceId])
  @@index([workspaceId, folderId])
  @@index([workspaceId, status])
  @@index([ownerUserId])
  @@map("documents")
}

model DocumentVersion {
  id            String   @id @default(cuid())
  documentId    String
  versionNumber Int
  storageKey    String
  fileSizeBytes BigInt
  mimeType      String
  uploadedById  String
  createdAt     DateTime @default(now())

  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  uploadedBy User     @relation("VersionUploader", fields: [uploadedById], references: [id])

  @@unique([documentId, versionNumber])
  @@map("document_versions")
}

model DocumentTag {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  color       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  documents DocumentTagMapping[]

  @@index([workspaceId])
  @@map("document_tags")
}

model DocumentTagMapping {
  id         String @id @default(cuid())
  documentId String
  tagId      String

  document Document    @relation(fields: [documentId], references: [id], onDelete: Cascade)
  tag      DocumentTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([documentId, tagId])
  @@map("document_tag_mappings")
}

model DocumentMetadata {
  id         String   @id @default(cuid())
  documentId String
  key        String
  value      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([documentId, key])
  @@map("document_metadata")
}

// ================================================================== //
// Search
// ================================================================== //

model DocumentSearchContent {
  id            String   @id @default(cuid())
  documentId    String   @unique
  extractedText String   @db.Text
  lastIndexedAt DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("document_search_content")
}
