// DockyDoc — Prisma Schema
// PostgreSQL datasource
//
// Run after changes:
//   npx prisma migrate dev --name <migration_name>
//   npx prisma generate
//
// Models will be added incrementally as features are built.
// Next steps: User, Workspace, WorkspaceMember, Document, AuditLog

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------------------ //
// Models are intentionally empty at this stage.
