# ============================================================
# DockyDoc API — Environment Variables
# Copy to .env (local) or set in Render dashboard (staging/production)
#
# REQUIRED in production (app exits on startup if missing):
#   DATABASE_URL, CORS_ORIGINS, SHARE_GRANT_SECRET,
#   ENCRYPTION_KEY, CLERK_SECRET_KEY
# ============================================================

# ─── App ────────────────────────────────────────────────────
# development | staging | production
NODE_ENV=development

# Render injects PORT automatically; only set manually for local dev
PORT=8081

# ─── Database ───────────────────────────────────────────────
# Local dev: use docker-compose postgres
# Staging/Production: use separate Neon branches (see DEPLOYMENT.md)
DATABASE_URL="postgresql://dockydoc:dockydoc_secret@localhost:5432/dockydoc_dev?schema=public"

# ─── JWT ────────────────────────────────────────────────────
# MUST be changed before any deployment.
# Generate: openssl rand -hex 32
JWT_SECRET=change_me_before_production
JWT_EXPIRES_IN=7d

# ─── Redis ──────────────────────────────────────────────────
# Optional for initial dev. Required if session caching is enabled.
REDIS_URL=redis://localhost:6379

# ─── CORS ───────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Local:      http://localhost:8080
# Staging:    https://dockydoc-staging.vercel.app
# Production: https://app.yourdomain.com
CORS_ORIGINS=http://localhost:8080

# ─── Security Secrets ───────────────────────────────────────
# REQUIRED in production. Generate each with: openssl rand -hex 32
SHARE_GRANT_SECRET=replace_with_output_of_openssl_rand_hex_32
ENCRYPTION_KEY=replace_with_output_of_openssl_rand_hex_32

# ─── Clerk SSO ──────────────────────────────────────────────
# Get from https://dashboard.clerk.com → API Keys
# Use test/dev keys for local dev and staging; live keys for production.
# Leave blank to fall back to x-dev-user-email header (local dev only).
CLERK_SECRET_KEY=sk_test_...

# ─── Storage ────────────────────────────────────────────────
# Default: 'local' (uploads stored in api/uploads/)
# For production, use 's3' with an S3-compatible bucket (AWS, Cloudflare R2, etc.)
# STORAGE_PROVIDER=s3
# S3_BUCKET=dockydoc
# S3_REGION=us-east-1
# S3_ENDPOINT=https://...          # omit for AWS, set for R2/MinIO
# S3_ACCESS_KEY_ID=...
# S3_SECRET_ACCESS_KEY=...

# ─── AI / OCR Providers ─────────────────────────────────────
# All optional — system degrades gracefully to available providers.
# Priority: Azure DI → Mistral OCR → Claude Native
#
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-proj-...
# AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://<name>.cognitiveservices.azure.com/
# AZURE_DOCUMENT_INTELLIGENCE_KEY=<key>
# MISTRAL_API_KEY=...
