# ============================================================
# DockyDoc API — Environment Variables
# Copy to .env and fill in values before running locally
# ============================================================

# Application
NODE_ENV=development
PORT=8081

# Database (PostgreSQL via Prisma)
DATABASE_URL="postgresql://dockydoc:dockydoc_secret@localhost:5432/dockydoc_dev?schema=public"

# JWT (change secret before going to production)
JWT_SECRET=change_me_before_production
JWT_EXPIRES_IN=7d

# Redis (for sessions / caching — optional for initial dev)
REDIS_URL=redis://localhost:6379

# CORS — allowed frontend origin(s)
CORS_ORIGINS=http://localhost:8080

# Share grant HMAC secret — required, must be ≥32 chars
# Generate with: openssl rand -hex 32
SHARE_GRANT_SECRET=replace_with_output_of_openssl_rand_hex_32

# Storage provider: 'local' (default) or 's3'
# STORAGE_PROVIDER=s3
# S3_BUCKET=dockydoc
# S3_REGION=us-east-1
# S3_ENDPOINT=http://localhost:9000  # For MinIO
# S3_ACCESS_KEY_ID=minioadmin
# S3_SECRET_ACCESS_KEY=minioadmin

# ============================================================
# AI / OCR Providers
# All are optional — system gracefully degrades to available providers
# Priority order: Azure DI → Mistral OCR → Claude Native
# ============================================================

# Anthropic (Claude) — used for extraction fallback and analysis
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — GPT-4o Structured Outputs (highest-quality field extraction)
# OPENAI_API_KEY=sk-proj-...

# Azure Document Intelligence — best OCR with layout + key-value pair detection
# AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://<name>.cognitiveservices.azure.com/
# AZURE_DOCUMENT_INTELLIGENCE_KEY=<key>

# Mistral OCR — markdown-aware OCR for PDFs and images
# MISTRAL_API_KEY=...

# Encryption key for BYOK API keys (64 hex chars = 32 bytes AES-256)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=replace_with_output_of_openssl_rand_hex_32

# Future: Keycloak / OIDC
# KEYCLOAK_URL=http://localhost:8080
# KEYCLOAK_REALM=dockydoc
# KEYCLOAK_CLIENT_ID=dockydoc-api
# KEYCLOAK_CLIENT_SECRET=
