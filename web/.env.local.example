# Copy this to .env.local and fill in values

# Public app config
NEXT_PUBLIC_APP_NAME=DockyDoc
NEXT_PUBLIC_API_URL=http://localhost:3001

# Auth (NextAuth.js / custom JWT — configure when implementing auth)
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=your-secret-here

# Keycloak / OIDC (for future SSO integration)
# KEYCLOAK_CLIENT_ID=dockydoc
# KEYCLOAK_CLIENT_SECRET=
# KEYCLOAK_ISSUER=http://localhost:8080/realms/dockydoc
