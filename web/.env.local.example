# ============================================================
# DockyDoc Web — Environment Variables
# Copy to .env.local (local dev) or set in Vercel dashboard
#
# NEXT_PUBLIC_* vars are baked into the client bundle at build time.
# NEXT_PUBLIC_API_URL must be set in Vercel before every deploy.
# ============================================================

# ─── API ────────────────────────────────────────────────────
# API_URL is the server-side (Vercel serverless) backend URL used by the
# /api/v1/* proxy route.  Browser calls always go through the proxy, so
# CORS is never an issue and NEXT_PUBLIC_API_URL is no longer required.
#
# Local:      http://localhost:8081
# Staging:    https://dockydoc-api-staging.onrender.com
# Production: https://dockydoc-api.onrender.com  (or your custom domain)
#
# Set API_URL (NOT NEXT_PUBLIC_API_URL) in the Vercel dashboard under
# Settings → Environment Variables.  The proxy route falls back to the
# staging Render URL automatically if neither var is set.
API_URL=http://localhost:8081

# Legacy — no longer needed for browser calls (kept for SSR edge cases).
# NEXT_PUBLIC_API_URL=http://localhost:8081

# ─── App ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=DockyDoc

# ─── Clerk SSO ──────────────────────────────────────────────
# Get from https://dashboard.clerk.com → API Keys
# Use the test/dev instance keys locally and for staging preview.
# Switch to the live instance keys for production.
#
# IMPORTANT: NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY is embedded in the bundle.
# If you change Clerk instances (test → live) you must redeploy.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk redirect URLs — keep these as-is unless you rename your routes
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# ─── Dev fallback ───────────────────────────────────────────
# Used ONLY when Clerk is not configured (no publishable key set).
# The API accepts this email via x-dev-user-email header in non-production.
# Leave unset in staging/production — Clerk handles auth there.
# NEXT_PUBLIC_DEV_USER_EMAIL=alice@acmecorp.com
